# Postgres (see repo root docker-compose.yml)
DB_HOST=localhost
DB_PORT=5556
DB_USERNAME=zoa
DB_PASSWORD=zoa
DB_NAME=zoa_db
TYPEORM_SYNC=true
DB_LOGGING=false

# Cloudflare R2 (S3-compatible). When all are set, `npm run sync-images` uploads
# Commons thumbnails to the bucket and stores the public URL in `image_urls`.
# Do not commit real secrets; copy to `.env` and fill locally.
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zoa-microbe-media-bucket
R2_REGION=auto
# Public base URL for objects (R2 custom domain or public r2.dev URL), no trailing slash
R2_PUBLIC_BASE_URL=https://YOUR_PUBLIC_HOST
