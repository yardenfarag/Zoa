# Nest API (local default). Used by archive list/detail pages.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (https://supabase.com/dashboard → Project Settings → API)
# Use either the publishable key (new) or the anon key (legacy) — not the service_role key in the browser.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy alternative (still supported by Supabase and this app):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
